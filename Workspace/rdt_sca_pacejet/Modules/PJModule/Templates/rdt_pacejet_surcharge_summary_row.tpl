{{#if showSurcharge}}
  <p
    class="order-wizard-cart-summary-grid-float rdt-pj-surcharge-row"
    data-type="rdt-pj-surcharge-row"
  >
    <span
      class="order-wizard-cart-summary-grid-right rdt-pj-surcharge-value"
    >{{surchargeFormatted}}</span>
    <span
      class="order-wizard-cart-summary-grid-left rdt-pj-surcharge-label"
    >{{surchargeLabel}}</span>
  </p>
{{/if}}